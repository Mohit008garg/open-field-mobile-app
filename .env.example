# Copy to .env and fill in your Google OAuth client IDs.
# EXPO_PUBLIC_* vars are inlined into the app at build time (they are not secret —
# Google OAuth client IDs are safe to ship in a mobile client).
#
# Create the client IDs in Google Cloud Console -> APIs & Services -> Credentials:
#   - Web client ID      : used by Expo Go / web
#   - Android client ID  : package name in.openfield.app + your SHA-1
#   - iOS client ID      : bundle id in.openfield.app
# Add the Expo redirect URIs per https://docs.expo.dev/guides/google-authentication/

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=""
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=""
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=""

# Backend API base URL. Leave unset to use the dev defaults
# (Android emulator -> http://10.0.2.2:3000, iOS/web -> http://localhost:3000).
# For a physical device on your LAN, set your machine's IP, e.g. http://192.168.1.5:3000
EXPO_PUBLIC_API_BASE_URL=""
